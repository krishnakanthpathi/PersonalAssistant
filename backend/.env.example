# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# gRPC Configuration (Optional)
GRPC_PORT=50051

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=assistant_platform

# Chroma Vector Database Configuration
CHROMA_URL=http://localhost:8000

# LLM Orchestrator Provider: 'openai' (standard API, GitHub Models, etc.), 'ollama' (local), or 'grok' (X.AI)
LLM_PROVIDER=openai

# OpenAI / Compatible API Settings (GitHub Models, Bedrock, NIM, standard OpenAI)
OPENAI_API_KEY=your_openai_api_key_or_github_pat_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_PROJECT_ID=default

# Ollama Local LLM Settings (Only active if LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Groq / Grok Settings (Only active if LLM_PROVIDER=grok)
GROK_API_KEY=your_groq_or_xai_api_key_here
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

# RAG Settings (Dynamic Tool Filtering & Similarity)
MAX_RELEVANT_TOOLS=10
TOOL_SIMILARITY_THRESHOLD=0.25

# Personal Long-Term Memory (RAG DB) Settings
RAG_PERSONAL_DB_LIMIT=8
RAG_PERSONAL_DB_THRESHOLD=0.20

# Embedding Generation Configuration
# EMBEDDING_PROVIDER can be 'openai' or 'ollama' (falls back to openai if API key is set, otherwise ollama)
EMBEDDING_PROVIDER=ollama
EMBEDDING_API_KEY=your_openai_embedding_key_if_applicable
EMBEDDING_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Optional Integrations & MCP Server Configurations ---

# Google OAuth Integrations (for Calendar / Gmail MCP servers)
# Note: Google Calendar requires credentials file in backend/gcp-oauth.keys.json
# and syncs tokens dynamically to MongoDB and data/google-calendar-token.json
# GOOGLE_OAUTH_CREDENTIALS=/absolute/path/to/gcp-oauth.keys.json
# GOOGLE_CALENDAR_MCP_TOKEN_PATH=/absolute/path/to/data/google-calendar-token.json

# Notion Integration
NOTION_TOKEN=your_notion_internal_integration_token_here
NOTION_PARENT_PAGE_ID=your_notion_default_parent_page_id_here

# YouTube API Integration
YOUTUBE_API_KEY=your_youtube_api_key_here

# Firecrawl Web Scraper
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Brave Search API Integration
BRAVE_API_KEY=your_brave_api_key_here

# WhatsApp Integration
# Format: country_code + number + @s.whatsapp.net (e.g., 919876543210@s.whatsapp.net)
# WHATSAPP_TARGET_NUMBER=your_recipient_whatsapp_id
# WHATSAPP_ALLOWED_NUMBERS=comma_separated_allowed_numbers

# macOS Process Executor Allow-list
# A colon-separated list of additional commands allowed to run via native process tools
MAC_MCP_PROCESS_ALLOW=Safari:Google Chrome:Terminal