# Server Port
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# LLM Provider: 'openai' (GitHub Models, Azure, or standard OpenAI) or 'ollama' (Local execution)
LLM_PROVIDER=openai

# OpenAI / GitHub Models Configuration
# (For GitHub Models, use: https://models.inference.ai.azure.com)
OPENAI_API_KEY=your_openai_or_github_pat_key_here
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Ollama Local Configuration (Only required if LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Notion MCP Configuration
NOTION_TOKEN=your_notion_internal_integration_token_here
NOTION_PARENT_PAGE_ID=your_notion_default_parent_page_id_here

# Tool RAG (Dynamic Selection) Configuration
MAX_RELEVANT_TOOLS=10
TOOL_SIMILARITY_THRESHOLD=0.25
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional integrations
BRAVE_API_KEY=your_brave_api_key_here

# Groq / Grok Configuration (Only required if LLM_PROVIDER=grok)
GROK_API_KEY=your_groq_or_xai_api_key_here
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

FIRECRAWL_API_KEY=test