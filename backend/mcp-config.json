{
	"mcpServers": {
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/Users/krishnakanth/Projects/PersonalAssisstent"
			]
		},
		"notion": {
			"command": "npx",
			"args": [
				"-y",
				"@notionhq/notion-mcp-server"
			]
		},
		"google-calendar": {
			"command": "npx",
			"args": [
				"-y",
				"@cocal/google-calendar-mcp"
			],
			"env": {
				"GOOGLE_OAUTH_CREDENTIALS": "/Users/krishnakanth/Projects/PersonalAssisstent/backend/gcp-oauth.keys.json",
				"GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/Users/krishnakanth/Projects/PersonalAssisstent/backend/data/google-calendar-token.json"
			}
		},
		"youtube": {
			"command": "/Users/krishnakanth/Projects/PersonalAssisstent/mcps/youtube-mcp/.venv/bin/python",
			"args": [
				"/Users/krishnakanth/Projects/PersonalAssisstent/mcps/youtube-mcp/youtube_server.py"
			],
			"env": {
				"YOUTUBE_API_KEY": "YOUR_YOUTUBE_API_KEY_HERE"
			}
		},
		"firecrawl": {
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp"
			],
			"env": {
				"FIRECRAWL_API_KEY": ""
			}
		},
		"gmail": {
			"command": "npx",
			"args": [
				"-y",
				"@shinzolabs/gmail-mcp"
			],
			"env": {
				"PORT": "0"
			}
		}
	}
}