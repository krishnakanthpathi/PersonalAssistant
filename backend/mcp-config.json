{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~"
      ],
      "enabled": false
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ]
    },
    "google-calendar": {
      "command": "npx",
      "args": [
        "-y",
        "@cocal/google-calendar-mcp"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "./gcp-oauth.keys.json",
        "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "./data/google-calendar-token.json"
      }
    },
    "youtube": {
      "command": "./mcps/youtube-mcp/.venv/bin/python",
      "args": [
        "./mcps/youtube-mcp/youtube_server.py"
      ],
      "env": {
        "YOUTUBE_API_KEY": "YOUR_YOUTUBE_API_KEY_HERE"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": ""
      },
      "enabled": true
    },
    "gmail": {
      "command": "npx",
      "args": [
        "-y",
        "@shinzolabs/gmail-mcp"
      ],
      "env": {
        "PORT": "0"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "./data/memory.json"
      }
    },
    "video-converter": {
      "command": "./mcps/mcp-video-converter/mcp-video-converter/.venv/bin/python",
      "args": [
        "-m",
        "mcp_video_converter.server"
      ],
      "enabled": false
    },
    "terminal": {
      "command": "node",
      "args": [
        "./mcps/terminal-mcp/index.js"
      ],
      "env": {
        "ALLOWED_COMMANDS": "npm,node,git,ls,echo,cat,pwd"
      }
    },
    "native-assistant": {
      "command": "./mcps/native-assistant-mcp/.venv/bin/python",
      "args": [
        "./mcps/native-assistant-mcp/server.py"
      ],
      "enabled": true
    },
    "mcp-mathematics": {
      "command": "uvx",
      "args": [
        "mcp-mathematics"
      ]
    },
    "sympy-mcp": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "einsteinpy",
        "--with",
        "mcp[cli]",
        "--with",
        "pydantic",
        "--with",
        "sympy",
        "mcp",
        "run",
        "/ABSOLUTE_PATH_TO_SYMPY_MCP/server.py"
      ]
    },
    "sequential-thinking": {
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "NODE_PATH": "/Users/krishnakanth/Projects/PersonalAssisstent/backend/node_modules"
      }
    }
  }
}