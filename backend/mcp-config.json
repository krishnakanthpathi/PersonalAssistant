{
	"mcpServers": {
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant"
			]
		},
		"notion": {
			"command": "npx",
			"args": [
				"-y",
				"@notionhq/notion-mcp-server"
			]
		},
		"google-calendar": {
			"command": "npx",
			"args": [
				"-y",
				"@cocal/google-calendar-mcp"
			],
			"env": {
				"GOOGLE_OAUTH_CREDENTIALS": "/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant/backend/gcp-oauth.keys.json",
				"GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant/backend/data/google-calendar-token.json"
			}
		},
		"firecrawl": {
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp"
			],
			"env": {
				"FIRECRAWL_API_KEY": ""
			}
		},
		"gmail": {
			"command": "npx",
			"args": [
				"-y",
				"@shinzolabs/gmail-mcp"
			],
			"env": {
				"PORT": "0"
			}
		},
		"github": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			]
		},
		"memory": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"env": {
				"MEMORY_FILE_PATH": "/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant/backend/data/memory.json"
			}
		},
		"mac": {
			"command": "/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant/mcps/mac-mcp/.venv/bin/python",
			"args": [
				"/Users/srivenkataaryapandrangi/Desktop/Jarvis/PersonalAssistant/mcps/mac-mcp/mac_server.py"
			]
		}
	}
}